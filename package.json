{
  "name": "orbit-diff",
  "private": true,
  "type": "module",
  "bin": {
    "orbit-diff": "./index.jsx"
  },
  "scripts": {
    "start": "bun index.jsx",
    "build": "bun build ./index.jsx --compile --outfile dist/orbit-diff",
    "install:local": "bun run build && mkdir -p \"$HOME/.local/bin\" && cp dist/orbit-diff \"$HOME/.local/bin/orbit-diff\" && echo \"installed orbit-diff -> $HOME/.local/bin/orbit-diff\""
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "cli-highlight": "^2.1.11",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "ink-testing-library": "^4.0.0",
    "react-devtools-core": "^7.0.1"
  }
}
